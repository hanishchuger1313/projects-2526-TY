tion.messages" tabindex="0"><div class="x12lumcd xx9tyur"></div><div class="x78zum5 x1okw0bk xl56j7k xqy66fx xyri2b x1hhzuzn x1c1uobl"><div class="x1bvqhpb x6f6fmj x1b9z3ur x9f619 x1rg5ohu x1okw0bk x193iq5w x123j3cw xpdmqnj x10b6aqq x1g0dm76 x13a8xbf xdod15v x2b8uid xyi3aci xwf5gio x1p453bz x1suzm8a"><div class="x78zum5 x6s0dn4 x1r0jzty x17zd0t2"><div>Use WhatsApp on your phone to see older messages.</div></div></div></div><div tabindex="0" class="x3psx0u x12xbjc7 x1c1uobl xrmvbpv xh8yej3 xquzyny xvc5jky x11t971q" data-tab="8"><div class="x141l45o x1h3r9g6 x1hx0egp x78zum5 x1q0g3np xl56j7k xscbp6u" tabindex="-1"><div class="x1n2onr6 x9f619 x1rg5ohu x1okw0bk x193iq5w x1tiyuxx x1nbhmlj x1iw51ew xde1mab xhslqc4 x2b8uid x1k43qru xrxyp3c xv0oops x1isl5vh xn8zj9a x148chh3"><span dir="auto" class="x140p0ai x1gufx9m x1s928wv xhkezso x1gmr53x x1cpjm7i x1fgarty x1943h6x x193iq5w xeuugli x13faqbe x1vvkbs x1lliihq x1fj9vlw xhslqc4 x1hx0egp x1pg5gke xjb2p0i xfjzk2p xl2ypbo x1ic7a3i" style="--x-fontSize: 12px; --x-lineHeight: 8.5313px; --x-8dd7yt: -0.0137em; --x-hxtmnb: 0.0137em;">4/4/2026</span></div></div><div class="x1n2onr6"><div><div tabindex="-1" class="" role="row"><div tabindex="-1" class="_amjv xa0aww2" data-id="false_919112741325@c.us_3EB01543BEE2EC4FF0D9EC"><div class="x78zum5 xdt5ytf" data-virtualized="false"><div class=""><div class="message-in focusable-list-item _amjy _amjz _amjw x1klvx2g xahtqtb"><span class=""></span><div class="_amk4 false false _amkd _amk5 false"><span aria-hidden="true" data-icon="tail-in" class="_amk7"><svg viewBox="0 0 8 13" height="13" width="8" preserveAspectRatio="xMidYMid meet" class="" version="1.1" x="0px" y="0px" enable-background="new 0 0 8 13"><title>tail-in</title><path opacity="0.13" fill="#0000000" d="M1.533,3.568L8,12.193V1H2.812 C1.042,1,0.474,2.156,1.533,3.568z"></path><path fill="currentColor" d="M1.533,2.568L8,11.193V0L2.812,0C1.042,0,0.474,1.156,1.533,2.568z"></path></svg></span><div class="_amk6 _amlo false false"><span aria-label="Priti Patil:"></span><div><div class="x9f619 x1hx0egp x1yrsyyn xizg8k xu9hqtb xwib8y2"><div class="copyable-text" data-pre-plain-text="[12:05 am, 4/4/2026] Priti Patil: "><div class="_akbu x6ikm8r x10wlt62"><span data-testid="selectable-text" dir="ltr" class="x1f6kntn xjb2p0i x8r4c90 xo1l8bm x1ic7a3i x12xpedu _ao3e _aupe copyable-text" style="min-height: 0px;"><span class="x1lliihq">.about-container {
</span><span class="x1lliihq">  min-height: 100vh;
</span><span class="x1lliihq">  background-size: cover;
</span><span class="x1lliihq">  background-position: center;
</span><span class="x1lliihq">  display: flex;
</span><span class="x1lliihq">  justify-content: center;
</span><span class="x1lliihq">  align-items: center;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* <img crossorigin="anonymous" alt="🔥" draggable="false" data-testid="selectable-text" class="b77 emoji wa  _ao3e _aupe copyable-text" data-plain-text="🔥" tabindex="-1" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" style="background-position: 0px -20px;"> overlay glass effect */
</span><span class="x1lliihq">/* .overlay {
</span><span class="x1lliihq">  background: rgba(255, 255, 255, 0.85);
</span><span class="x1lliihq">  padding: 40px;
</span><span class="x1lliihq">  border-radius: 15px;
</span><span class="x1lliihq">  text-align: center;
</span><span class="x1lliihq">  width: 90%;
</span><span class="x1lliihq">  max-width: 900px;
</span><span class="x1lliihq">} */
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* Title */
</span><span class="x1lliihq">.about-title {
</span><span class="x1lliihq">  font-size: 36px;
</span><span class="x1lliihq">  color: #0077b6;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* Text */
</span><span class="x1lliihq">.about-text {
</span><span class="x1lliihq">  font-size: 16px;
</span><span class="x1lliihq">  margin-bottom: 25px;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* Gallery */
</span><span class="x1lliihq">.image-gallery {
</span><span class="x1lliihq">  display: flex;
</span><span class="x1lliihq">  justify-content: center;
</span><span class="x1lliihq">  gap: 150px;
</span><span class="x1lliihq">  margin-bottom: 30px;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* Card */
</span><span class="x1lliihq">.card {
</span><span class="x1lliihq">  background: #fff;
</span><span class="x1lliihq">  padding: 10px;
</span><span class="x1lliihq">  border-radius: 80px;
</span><span class="x1lliihq">  width: 150px;
</span><span class="x1lliihq">  box-shadow: 0 20px 30px rgba(0,0,0,0.2);
</span><span class="x1lliihq">  transition: 0.3s;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">.card:hover {
</span><span class="x1lliihq">  transform: translateY(-5px);
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* Image */
</span><span class="x1lliihq">.card img {
</span><span class="x1lliihq">  width: 100%;
</span><span class="x1lliihq">  height: 250px;
</span><span class="x1lliihq">  object-fit: cover;
</span><span class="x1lliihq">  border-radius: 8px;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* Caption */
</span><span class="x1lliihq">.card p {
</span><span class="x1lliihq">  margin-top: 20px;
</span><span class="x1lliihq">  font-size: 13px;
</span><span class="x1lliihq">  color: #0077b6;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* <img crossorigin="anonymous" alt="🎥" draggable="false" data-testid="selectable-text" class="b26 emoji wa  _ao3e _aupe copyable-text" data-plain-text="🎥" tabindex="-1" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" style="background-position: -80px -80px;"> Video */
</span><span class="x1lliihq">.video-section h2 {
</span><span class="x1lliihq">  margin-bottom: 10px;
</span><span class="x1lliihq">  color: #023e8a;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">.video {
</span><span class="x1lliihq">  width: 200%;
</span><span class="x1lliihq">  max-width: 600px;
</span><span class="x1lliihq">  border-radius: 10px;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* <img crossorigin="anonymous" alt="🔙" draggable="false" data-testid="selectable-text" class="b76 emoji wa  _ao3e _aupe copyable-text" data-plain-text="🔙" tabindex="-1" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" style="background-position: -60px -60px;"> Back Button Fix */
</span><span class="x1lliihq">.back-btn {
</span><span class="x1lliihq">  position: fixed;   /* <img crossorigin="anonymous" alt="👈" draggable="false" data-testid="selectable-text" class="b37 emoji wa  _ao3e _aupe copyable-text" data-plain-text="👈" tabindex="-1" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" style="background-position: 0px -20px;"> screen ला stick होईल */
</span><span class="x1lliihq">  top: 20px;
</span><span class="x1lliihq">  left: 20px;
</span><span class="x1lliihq">  padding: 10px 18px;
</span><span class="x1lliihq">  border-radius: 10px;
</span><span class="x1lliihq">  border: none;
</span><span class="x1lliihq">  background: linear-gradient(45deg, #0077b6, #00b4d8);
</span><span class="x1lliihq">  color: white;
</span><span class="x1lliihq">  cursor: pointer;
</span><span class="x1lliihq">  font-weight: bold;
</span><span class="x1lliihq">  box-shadow: 0 3px 8px rgba(0,0,0,0.3);
</span><span class="x1lliihq">  z-index: 9999;   /* <img crossorigin="anonymous" alt="👈" draggable="false" data-testid="selectable-text" class="b37 emoji wa  _ao3e _aupe copyable-text" data-plain-text="👈" tabindex="-1" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" style="background-position: 0px -20px;"> overlay/video वरून दिसेल */
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">.back-btn:hover {
